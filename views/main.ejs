<head>
  <meta charset="utf-8">
  <title>Crochet Hub</title>

  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/v4-shims.css">
  <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
  <link rel="stylesheet" href="css/main3.css">
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css"
    integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"
    integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n"
    crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"
    integrity="sha384-JjSmVgyd0p3pXB1rRibZUAYoIIy6OrQ6VrjIEaFf/nJGzIxFDsf4x0xIM+B07jRM"
    crossorigin="anonymous"></script>
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

  <!-- ✅ NEW: Arabic font -->
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body>

  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script>
    AOS.init();
  </script>


<section id="title" class="hero">

  <nav class="navbar navbar-expand-lg hero-nav">
    <a class="navbar-brand hero-brand" data-aos="fade-up" href="#title">Crochet Hub</a>

    <button class="navbar-toggler hero-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent" data-aos="fade-up">
      <ul class="navbar-nav ml-auto hero-links">

        <li class="nav-item">
          <a class="nav-link hero-link" href="#footer">تواصل معنا</a>
        </li>

        <li class="nav-item">
          <a class="nav-link hero-link" href="#about">عن المنصة</a>
        </li>

        <li class="nav-item">
          <a class="nav-link hero-link" href="#Searcher">المحتوى</a>
        </li>

        <li class="nav-item">
          <a class="nav-link hero-link hero-link-cta" data-toggle="modal" data-target="#exampleModal2" href="">
            تسجيل دخول
          </a>
        </li>

        <li class="nav-item active">
          <a class="nav-link hero-link hero-link-active" href="#title">الصفحة الرئيسية</a>
        </li>

      </ul>
    </div>
  </nav>

  <div class="container hero-container">

    <% if (message) { %>
      <div class="alert alert-danger alert-dismissible fade show hero-alert">
        <strong>!!خطأ</strong> البيانات غير صحيحة أو الحساب موجود مسبقًا
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    <% } %>

    <% if (message2) { %>
      <div class="alert alert-success alert-dismissible fade show hero-alert">
        <a href="/">للعودة من هنا</a> تم إرسال البيانات بنجاح
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    <% } %>

    <div class="row hero-row" data-aos="fade-up">

      <div class="col-lg-6 hero-copy">
        <h1 class="hero-title">Crochet Hub</h1>

        <p class="hero-subtitle">
          منصة كروشيه تجمع كل شيء في مكان واحد:
          دورات تعليمية، ملفات باترن PDF، ومنتجات كروشيه مع تفاصيلها.
          هدفنا تسهيل التعلم، البيع، والاحتراف من أول غرزة إلى آخر عقدة.
        </p>
      </div>

      <div class="col-lg-6 hero-cta">
        <section id="Searcher" class="hero-search">
          <div class="Searcher-box">
            <a class="icon_search" href="/display_product" aria-label="عرض المنتجات">
              <i class="fas fa-shopping-bag"></i>
              <span class="icon_search_text">عرض المنتجات</span>
            </a>

            <div class="hero-search-text">
              <h3 class="h3_search">المنتجات والباترن</h3>
              <p class="P1_search">تصفح منتجات الكروشيه وملفات PDF الخاصة بها</p>
            </div>
          </div>
        </section>
      </div>

    </div>
  </div>

</section>

  <% if (message) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <strong>!!خطأ</strong> هذا الحساب موجود بالفعل
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
  <% } %>

  <% if (message2) { %>
    <div class="alert alert-success" role="alert">
      مبروك! تم إنشاء الحساب بنجاح
      <a href="/" class="alert-link">اضغط هنا للذهاب إلى صفحة الدخول</a>
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
  <% } %>


  <footer id="footer" class="site-footer" data-aos="fade-up">
    <div class="container">
      <div class="row footer-grid">
  
        <div class="col-md-3 footer-col">
          <div class="footer-brand">
            <i class="footer-title">CROCHET HUB</i>
            <p class="footer-tagline">نعلّم ونصنع ونبيع</p>
          </div>
        </div>
  
        <div class="col-md-3 footer-col">
          <i class="footer-title">Explorer</i>
          <ul class="footer-links">
            <li><a href="#">Home</a></li>
            <li><a href="#">About</a></li>
          </ul>
        </div>
  
        <div class="col-md-3 footer-col">
          <i class="footer-title">Email</i>
          <p class="footer-contact">
            <i class="fas fa-envelope"></i>
            <span>zwali.eng@gmail.com</span>
          </p>
        </div>
  
        <div class="col-md-3 footer-col">
          <i class="footer-title">Connect with us</i>
          <div class="footer-social">
            <a href="#" class="social-btn" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="social-btn" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
            <a href="#" class="social-btn" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
  
      </div>
  
      <div class="footer-bottom">
        <p class="copy">© Copyright 2021 Crochet Hub</p>
      </div>
    </div>
  </footer>

  <!-- ✅ Modals: kept exactly (no link/action changes) -->
  <!-- Modal 1 -->
  <div class="modal fade" id="exampleModal2" tabindex="-1" role="dialog"
  aria-labelledby="exampleModalLabel" aria-hidden="true">

  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content auth-modal">

      <div class="modal-header auth-header">
        <h5 class="modal-title auth-title" id="exampleModalLabel">
          🧶 Crochet Hub
        </h5>
        <button type="button" class="close auth-close" data-dismiss="modal">&times;</button>
      </div>

      <div class="modal-body">

        <form action="/login" method="POST" class="auth-form">

          <h4 class="auth-subtitle">تسجيل دخول</h4>
          <p class="auth-desc">أهلاً بك، سجل دخولك وابدأ رحلتك في عالم الكروشيه</p>

          <div class="form-group auth-group">
            <label>البريد الإلكتروني</label>
            <div class="input-wrapper">
              <i class="fa fa-user"></i>
              <input name="email" class="form-control auth-input"
                placeholder="example@email.com" type="email" required>
            </div>
          </div>

          <div class="form-group auth-group">
            <label>كلمة المرور</label>
            <div class="input-wrapper">
              <i class="fa fa-lock"></i>
              <input name="password" class="form-control auth-input"
                placeholder="********" type="password" required>
            </div>
          </div>

          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <button type="submit" class="btn auth-btn btn-block">
            تسجيل الدخول
          </button>

          <div class="auth-links">
            <a href="/reset">نسيت كلمة المرور؟</a>
            <span>|</span>
            <a href="/crochet_Register">إنشاء حساب جديد</a>
          </div>

        </form>

      </div>

    </div>
  </div>
</div>



</body>

<script>
</script>

</html>