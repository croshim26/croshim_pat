<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Crochet Hub | طلب باترن بالذكاء الاصطناعي</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/request.css">
</head>

<body>

  <%- include("../partials/navbar") %>

  <main class="request-page">
    <div class="container">

      <header class="page-header" data-aos="fade-up">
        <div class="request-header-icon">
          <i class="fas fa-magic"></i>
        </div>
        <h1 class="request-title">طلب باترن بالذكاء الاصطناعي</h1>
        <p class="request-subtitle">
          صف لنا المنتج الذي تريده وسيقوم الذكاء الاصطناعي بإنشاء باترن كروشيه كامل واحترافي لك فوراً
        </p>
      </header>

      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">

          <!-- FORM CARD -->
          <div class="request-card" id="formCard" data-aos="fade-up" data-aos-delay="100">
            <div id="formError" class="alert alert-danger" style="display:none;"></div>

            <form id="patternPageForm" novalidate>
              <input type="hidden" id="pageCsrfField" value="<%= csrfToken %>">

              <div class="form-group">
                <label for="product_name">اسم الباترن <span class="required-star">*</span></label>
                <input
                  type="text"
                  class="form-control request-input"
                  id="product_name"
                  name="product_name"
                  placeholder="مثال: قبعة الشتاء الدافئة"
                  required
                >
              </div>

              <div class="form-section">
                <h3 class="form-section-title">
                  <i class="fas fa-list-alt"></i>
                  تفاصيل الطلب
                </h3>

                <div class="form-group">
                  <label for="product_type">نوع المنتج <span class="required-star">*</span></label>
                  <select class="form-control request-input" id="product_type" name="product_type" required>
                    <option value="" disabled selected>اختر نوع المنتج</option>
                    <option value="قبعة">قبعة</option>
                    <option value="وسادة">وسادة</option>
                    <option value="حقيبة">حقيبة</option>
                    <option value="بطانية">بطانية</option>
                    <option value="ملابس أطفال">ملابس أطفال</option>
                    <option value="إكسسوار">إكسسوار</option>
                    <option value="دمية">دمية / أميغورومي</option>
                    <option value="شال">شال أو وشاح</option>
                    <option value="ديكور منزلي">ديكور منزلي</option>
                    <option value="أخرى">أخرى</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="description">
                    وصف المنتج المطلوب <span class="required-star">*</span>
                    <span class="field-hint">كلما كانت التفاصيل أكثر، كان الباترن أدق</span>
                  </label>
                  <textarea
                    class="form-control request-input"
                    id="description"
                    name="description"
                    rows="4"
                    placeholder="مثال: قبعة دافئة للشتاء بشكل بسيط، مناسبة للبالغين، بحافة مضلعة من الأسفل..."
                    required
                  ></textarea>
                </div>

                <div class="form-row">
                  <div class="form-group col-12 col-md-6">
                    <label for="colors">الألوان المفضلة <span class="optional-label">(اختياري)</span></label>
                    <input
                      type="text"
                      class="form-control request-input"
                      id="colors"
                      name="colors"
                      placeholder="مثال: أبيض، بيج، وردي فاتح"
                    >
                  </div>

                  <div class="form-group col-12 col-md-6">
                    <label for="size_notes">المقاس أو الأبعاد <span class="optional-label">(اختياري)</span></label>
                    <input
                      type="text"
                      class="form-control request-input"
                      id="size_notes"
                      name="size_notes"
                      placeholder="مثال: مقاس للبالغين، 40×40 سم"
                    >
                  </div>
                </div>

                <div class="form-group">
                  <label for="additional_notes">ملاحظات إضافية <span class="optional-label">(اختياري)</span></label>
                  <textarea
                    class="form-control request-input"
                    id="additional_notes"
                    name="additional_notes"
                    rows="2"
                    placeholder="مستوى الصعوبة المفضل، نوع الخيط، أي تفاصيل خاصة..."
                  ></textarea>
                </div>
              </div>

              <button type="submit" class="btn request-submit-btn btn-block" id="generateBtn">
                <i class="fas fa-magic"></i>
                إنشاء الباترن بالذكاء الاصطناعي
              </button>
            </form>
          </div>

          <!-- LOADING CARD -->
          <div class="request-card loading-card" id="loadingCard" style="display:none;" data-aos="fade-up">
            <div class="loading-inner">
              <div class="loading-spinner">
                <div class="spinner-dot"></div>
                <div class="spinner-dot"></div>
                <div class="spinner-dot"></div>
              </div>
              <p class="loading-text">يقوم الذكاء الاصطناعي بإنشاء باترنك...</p>
              <p class="loading-sub">قد يستغرق ذلك بضع ثوانٍ</p>
            </div>
          </div>

          <!-- RESULT CARD -->
          <div class="result-card" id="resultCard" style="display:none;" data-aos="fade-up">

            <div class="result-header">
              <div class="result-header-left">
                <div class="result-badge">
                  <i class="fas fa-magic"></i>
                  باترن منشأ بالذكاء الاصطناعي
                </div>
                <h2 class="result-title" id="resultTitle"></h2>
              </div>
              <div class="result-actions">
                <a class="btn result-action-btn pdf-download-btn" id="downloadBtn" style="display:none;" target="_blank" rel="noopener noreferrer">
                  <i class="fas fa-file-pdf"></i><span>تحميل PDF</span>
                </a>
                <button class="btn result-action-btn" id="copyBtn">
                  <i class="fas fa-copy"></i><span>نسخ</span>
                </button>
                <button class="btn result-action-btn" id="printBtn">
                  <i class="fas fa-print"></i><span>طباعة</span>
                </button>
              </div>
            </div>

            <div class="result-body" id="patternOutput"></div>

            <div class="result-footer">
              <button class="btn new-request-btn" id="newRequestBtn">
                <i class="fas fa-redo-alt"></i>
                طلب باترن جديد
              </button>
              <p class="result-disclaimer">
                <i class="fas fa-info-circle"></i>
                تأكد دائماً من عدد الغرز أثناء التنفيذ، ويمكنك تعديل الباترن حسب احتياجك.
              </p>
            </div>

          </div>

        </div>
      </div>

    </div>
  </main>

  <%- include("../partials/footer") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>



  <script>
  (function () {
    var form        = document.getElementById('patternPageForm');
    var formCard    = document.getElementById('formCard');
    var loadingCard = document.getElementById('loadingCard');
    var resultCard  = document.getElementById('resultCard');
    var formError   = document.getElementById('formError');
    var resultTitle = document.getElementById('resultTitle');
    var patternOutput = document.getElementById('patternOutput');
    var copyBtn     = document.getElementById('copyBtn');
    var printBtn    = document.getElementById('printBtn');
    var downloadBtn = document.getElementById('downloadBtn');
    var newRequestBtn = document.getElementById('newRequestBtn');
    var rawPatternText = '';

    marked.setOptions({ breaks: true, gfm: true });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      formError.style.display = 'none';

      var productName = document.getElementById('product_name').value.trim();
      var productType = document.getElementById('product_type').value;
      var description = document.getElementById('description').value.trim();

      if (!productName || !productType || !description) {
        formError.textContent = 'يرجى تعبئة جميع الحقول الإلزامية.';
        formError.style.display = 'block';
        return;
      }

      formCard.style.display    = 'none';
      loadingCard.style.display = '';
      resultCard.style.display  = 'none';

      var payload = {
        product_name:     productName,
        product_type:     productType,
        description:      description,
        colors:           document.getElementById('colors').value.trim(),
        size_notes:       document.getElementById('size_notes').value.trim(),
        additional_notes: document.getElementById('additional_notes').value.trim(),
      };

      fetch('/api/generate_pattern', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.getElementById('pageCsrfField').value,
        },
        body: JSON.stringify(payload),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loadingCard.style.display = 'none';
          if (data.error) {
            formCard.style.display = '';
            formError.textContent = data.error;
            formError.style.display = 'block';
            return;
          }
          rawPatternText = data.pattern;
          resultTitle.textContent = 'باترن ' + productName;
          patternOutput.innerHTML = marked.parse(data.pattern);
          if (data.pdf_url) {
            downloadBtn.href = data.pdf_url;
            downloadBtn.style.display = '';
          } else {
            downloadBtn.style.display = 'none';
          }
          resultCard.style.display = '';
          resultCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
        })
        .catch(function () {
          loadingCard.style.display = 'none';
          formCard.style.display = '';
          formError.textContent = 'حدث خطأ في الاتصال. يرجى المحاولة مجدداً.';
          formError.style.display = 'block';
        });
    });

    copyBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(rawPatternText).then(function () {
        copyBtn.innerHTML = '<i class="fas fa-check"></i><span>تم النسخ!</span>';
        setTimeout(function () {
          copyBtn.innerHTML = '<i class="fas fa-copy"></i><span>نسخ</span>';
        }, 2000);
      });
    });

    printBtn.addEventListener('click', function () {
      var win = window.open('', '_blank');
      win.document.write(
        '<html dir="rtl"><head><meta charset="utf-8"><title>باترن كروشيه</title>' +
        '<style>body{font-family:Arial,sans-serif;padding:2rem;line-height:1.8;direction:rtl;}' +
        'h2,h3{color:#c97c5d;}</style></head><body>' +
        patternOutput.innerHTML + '</body></html>'
      );
      win.document.close();
      win.print();
    });

    newRequestBtn.addEventListener('click', function () {
      resultCard.style.display = 'none';
      formCard.style.display   = '';
      form.reset();
      formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();
  </script>

</body>
</html>
