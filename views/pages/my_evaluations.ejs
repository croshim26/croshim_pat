<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Croshim Studio | تقييماتي</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/products.css">
  <link rel="stylesheet" href="/css/pages/request.css">
</head>

<body>

  <%- include("../partials/navbar") %>

  <main class="products-page">
    <div class="container">

      <!-- ALERTS -->
      <% if (success_message) { %>
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
          <strong>تم بنجاح!</strong> <%= success_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>
      <% if (error_message) { %>
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
          <strong>خطأ!</strong> <%= error_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>

      <!-- WELCOME BANNER -->
      <div class="welcome-banner" data-aos="fade-up">
        <div class="welcome-info">
          <div class="welcome-avatar">
            <i class="fas fa-file-medical-alt"></i>
          </div>
          <div>
            <h2 class="welcome-name">
              أهلاً، <%= currentUser.firstName %> <%= currentUser.lastName %>
            </h2>
            <p class="welcome-sub">الباترنات التي قيّمها الذكاء الاصطناعي وحسّنها</p>
          </div>
        </div>
        <div class="welcome-stat">
          <span class="stat-count"><%= evaluations ? evaluations.length : 0 %></span>
          <span class="stat-label">تقييم</span>
        </div>
      </div>

      <header class="page-header" data-aos="fade-up">
        <h1 class="products-title">تقييماتي</h1>
        <p class="products-subtitle">جميع الباترنات التي رفعتها للتقييم والتحسين</p>
      </header>

      <div class="text-center mb-4" data-aos="fade-up">
        <a href="/evaluate_pattern" class="btn request-submit-btn px-4" style="display:inline-flex;">
          <i class="fas fa-file-medical-alt"></i>
          تقييم باترن جديد
        </a>
      </div>

      <div class="row">

        <% if (evaluations && evaluations.length > 0) { %>

          <% evaluations.forEach(function(item, index) { %>

            <div class="col-12 col-sm-6 col-md-4 mb-4" data-aos="fade-up" data-aos-delay="<%= index * 60 %>">
              <article class="card product-card">

                <div class="product-header">
                  <div class="ai-pattern-badge">
                    <i class="fas fa-file-medical-alt"></i> تقييم AI
                  </div>
                  <span class="label-title">اسم الملف الأصلي</span>
                  <h2 class="product-name" style="font-size:1rem; word-break:break-all;">
                    <%= item.original_filename %>
                  </h2>
                </div>

                <div class="product-body">

                  <div class="product-meta">
                    <span class="label-title">تاريخ التقييم</span>
                    <p class="product-description ai-date">
                      <i class="fas fa-calendar-alt" style="margin-left:4px;"></i>
                      <%= new Date(item.createdAt).toLocaleDateString('ar-SA') %>
                    </p>
                  </div>

                  <div class="product-meta">
                    <span class="label-title">الباترن المحسّن</span>
                    <% if (item.pdf_path) { %>
                      <a href="<%= item.pdf_path %>" target="_blank" rel="noopener noreferrer"
                        class="btn pdf-btn" style="font-size:0.85rem; padding:0.4rem 0.9rem;">
                        <i class="fas fa-file-pdf"></i>
                        تحميل الباترن المحسّن
                      </a>
                    <% } else { %>
                      <div class="no-file">
                        <i class="far fa-folder-open"></i>
                        لا يوجد ملف
                      </div>
                    <% } %>
                  </div>

                </div>

              </article>
            </div>

          <% }) %>

        <% } else { %>

          <div class="col-12" data-aos="fade-up">
            <div class="empty-state">
              <i class="fas fa-file-medical-alt empty-icon"></i>
              <h5>لا توجد تقييمات حالياً</h5>
              <p>ارفع باترنك الأول للتقييم والتحسين بالذكاء الاصطناعي!</p>
              <a href="/evaluate_pattern" class="btn pdf-btn mt-3">
                <i class="fas fa-file-medical-alt"></i> تقييم باترن جديد
              </a>
            </div>
          </div>

        <% } %>

      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>



</body>
</html>
