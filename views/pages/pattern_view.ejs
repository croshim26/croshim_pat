<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pattern.name %> — Croshim Studio</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">

  <style>
    /* ── Brand tokens ── */
    :root {
      --blush:     #F4C2C2;
      --rose:      #E8839A;
      --deep-rose: #C0516B;
      --mauve:     #9B3A52;
      --cream:     #FDF0F3;
      --soft-pink: #FAE4EA;
      --petal:     #F9D4DC;
      --text-dark: #5A2A38;
      --text-mid:  #8B4D60;
      --text-light:#B8798A;
      --code-bg:   #FDF5F7;
      --code-border:#EEC5CF;
    }

    body { background: #faf5f7; color: var(--text-dark); }

    /* ── Hero ── */
    .pv-hero {
      background: linear-gradient(155deg, #F9D4DC 0%, #F0A8B8 45%, #E07A94 100%);
      position: relative;
      overflow: hidden;
      padding: 70px 0 48px;
    }
    .pv-hero::before {
      content: ''; position: absolute; top: -100px; right: -100px;
      width: 380px; height: 380px; border-radius: 50%;
      background: rgba(255,255,255,.13); pointer-events: none;
    }
    .pv-hero::after {
      content: ''; position: absolute; bottom: -80px; left: -80px;
      width: 300px; height: 300px; border-radius: 50%;
      background: rgba(255,255,255,.09); pointer-events: none;
    }

    .pv-hero-inner {
      position: relative; z-index: 1;
      display: flex; flex-direction: column; align-items: center; text-align: center;
      gap: 0;
    }

    .pv-brand {
      font-family: 'Playfair Display', serif; font-style: italic;
      font-size: 1rem; color: rgba(155,58,82,.75);
      letter-spacing: 3px; margin-bottom: 20px;
    }

    .pv-cover-img {
      width: 180px; height: 180px; object-fit: cover; border-radius: 50%;
      border: 5px solid rgba(255,255,255,.75);
      box-shadow: 0 12px 48px rgba(155,58,82,.28);
      margin-bottom: 24px;
    }

    .pv-emoji { font-size: 3.5rem; margin-bottom: 14px; line-height: 1; }

    .pv-title {
      font-family: 'Noto Naskh Arabic', serif;
      font-size: 2.4rem; font-weight: 700;
      color: #fff; margin-bottom: 8px;
      text-shadow: 0 3px 16px rgba(155,58,82,.3);
    }
    .pv-subtitle {
      font-family: 'Noto Naskh Arabic', serif;
      font-size: 1.05rem; color: rgba(255,255,255,.87);
      margin-bottom: 28px;
    }

    .pv-actions {
      display: flex; gap: .6rem; justify-content: center; flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .pv-btn {
      display: inline-flex; align-items: center; gap: .4rem;
      padding: .6rem 1.4rem; border-radius: 14px; font-weight: 800;
      font-size: .88rem; font-family: 'Cairo', sans-serif;
      text-decoration: none; transition: .2s; cursor: pointer; border: 0;
    }
    .pv-btn-pdf {
      background: var(--mauve); color: #fff;
      box-shadow: 0 6px 20px rgba(155,58,82,.3);
    }
    .pv-btn-pdf:hover { background: #7a2d40; color: #fff; transform: translateY(-2px); text-decoration: none; }
    .pv-btn-print {
      background: rgba(255,255,255,.25); color: #fff;
      border: 1px solid rgba(255,255,255,.4);
    }
    .pv-btn-print:hover { background: rgba(255,255,255,.38); color: #fff; text-decoration: none; }

    /* dots */
    .pv-dots {
      display: flex; gap: 6px; justify-content: center; margin-top: 32px;
    }
    .pv-dots span {
      width: 7px; height: 7px; border-radius: 50%; display: inline-block;
    }
    .pv-dots span:nth-child(1) { background: rgba(255,255,255,.5); }
    .pv-dots span:nth-child(2) { background: rgba(255,255,255,.8); }
    .pv-dots span:nth-child(3) { background: rgba(255,255,255,.5); }
    .pv-dots span:nth-child(4) { background: rgba(255,255,255,.7); }
    .pv-dots span:nth-child(5) { background: rgba(255,255,255,.5); }
    .pv-dots span:nth-child(6) { background: rgba(255,255,255,.8); }

    /* ── Content ── */
    .pv-body { padding: 44px 0 60px; }

    .pv-card {
      background: #fff; border-radius: 20px;
      border: 1px solid rgba(196,99,122,.1);
      box-shadow: 0 4px 24px rgba(155,58,82,.07);
      margin-bottom: 24px; overflow: hidden;
    }
    .pv-card-head {
      padding: .9rem 1.4rem;
      border-bottom: 1px solid rgba(155,58,82,.07);
      display: flex; align-items: center; gap: .55rem;
    }
    .pv-card-head h2 {
      font-family: 'Cairo', sans-serif; font-weight: 900;
      font-size: 1rem; color: var(--mauve); margin: 0;
    }
    .pv-card-head .head-icon {
      font-size: 1.1rem; color: var(--rose);
    }
    .pv-card-body { padding: 1.2rem 1.4rem; }

    /* Tools table */
    .tools-tbl {
      width: 100%; border-collapse: separate; border-spacing: 0 5px;
      font-family: 'Noto Naskh Arabic', serif;
    }
    .tools-tbl td { padding: 8px 14px; font-size: .9rem; }
    .tools-tbl tr:nth-child(odd)  td { background: var(--soft-pink); }
    .tools-tbl tr:nth-child(even) td { background: var(--petal); }
    .tools-tbl td:last-child {
      border-radius: 9px 0 0 9px; font-weight: 700; color: var(--mauve);
    }
    .tools-tbl td:first-child {
      border-radius: 0 9px 9px 0; color: var(--text-light); font-size: .82rem;
    }

    /* Abbreviations grid */
    .abbr-grid-pub {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 8px;
    }
    .abbr-item-pub {
      background: var(--soft-pink); border-radius: 10px;
      padding: 7px 12px; display: flex; align-items: center;
      gap: 9px; border: 1px solid var(--code-border);
    }
    .abbr-key-pub {
      font-family: 'Courier New', monospace; font-weight: bold;
      font-size: .82rem; color: var(--deep-rose);
      background: #fff; border-radius: 6px; padding: 2px 9px;
      border: 1px solid var(--blush); flex-shrink: 0;
      min-width: 42px; text-align: center;
    }
    .abbr-val-pub {
      font-family: 'Lato', sans-serif; font-size: .76rem;
      color: var(--text-mid); direction: ltr; text-align: left;
    }

    /* Pattern parts */
    .part-heading {
      font-family: 'Noto Naskh Arabic', serif; font-size: 1.05rem; font-weight: 700;
      color: var(--deep-rose); margin: 0 0 10px;
      padding-right: 12px; border-right: 4px solid var(--rose);
      text-align: right;
    }
    .part-card {
      background: var(--code-bg); border: 1.5px solid var(--code-border);
      border-radius: 14px; padding: 14px 18px; margin-bottom: 10px;
      direction: ltr; text-align: left; position: relative; overflow: hidden;
    }
    .part-card::before {
      content: ''; position: absolute; top: 0; right: 0;
      width: 5px; height: 100%;
      background: linear-gradient(180deg, var(--rose), var(--blush));
      border-radius: 0 14px 14px 0;
    }
    .part-card code {
      font-family: 'Courier New', monospace; font-size: .85rem;
      color: var(--text-dark); line-height: 2; display: block;
      white-space: pre-wrap; word-break: break-word;
    }
    .part-note {
      background: linear-gradient(135deg, #FFF0F3, #FDE8EE);
      border: 1px solid var(--blush); border-radius: 11px;
      padding: 10px 14px; margin-top: 6px;
      display: flex; align-items: flex-start; gap: 9px;
      flex-direction: row-reverse;
      font-family: 'Noto Naskh Arabic', serif; font-size: .9rem;
      color: var(--text-mid); text-align: right;
    }
    .note-ico { font-size: 1rem; flex-shrink: 0; }

    /* Divider */
    .pv-divider {
      display: flex; align-items: center; gap: 12px;
      margin: 20px 0;
    }
    .pv-divider::before, .pv-divider::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(90deg, transparent, var(--blush), transparent);
    }
    .pv-divider span { font-size: 1rem; color: var(--rose); }

    /* ── print ── */
    @media print {
      .pv-hero { break-after: avoid; }
      .pv-actions, .hero-nav, footer { display: none !important; }
      .pv-card { box-shadow: none !important; border: 1px solid #eee !important; break-inside: avoid; }
    }

    @media (max-width: 576px) {
      .pv-title { font-size: 1.7rem; }
      .pv-cover-img { width: 130px; height: 130px; }
    }
  </style>
</head>
<body>

  <%- include("../partials/navbar") %>

  <!-- ── Hero ── -->
  <section class="pv-hero">
    <div class="container">
      <div class="pv-hero-inner" data-aos="fade-up">

        <div class="pv-brand">croshim studio</div>

        <% if (pattern.cover_image) { %>
          <img src="<%= pattern.cover_image %>" alt="<%= pattern.name %>" class="pv-cover-img">
        <% } else { %>
          <div class="pv-emoji"><%= pattern.emoji || '🧶' %></div>
        <% } %>

        <h1 class="pv-title"><%= pattern.name %></h1>

        <% if (pattern.subtitle) { %>
          <p class="pv-subtitle"><%= pattern.subtitle %></p>
        <% } %>

        <div class="pv-actions">
          <a href="/pattern/<%= pattern.id %>/pdf" target="_blank" class="pv-btn pv-btn-pdf">
            <i class="fas fa-file-pdf"></i>
            تحميل PDF
          </a>
          <button onclick="window.print()" class="pv-btn pv-btn-print">
            <i class="fas fa-print"></i>
            طباعة
          </button>
        </div>

        <div class="pv-dots">
          <span></span><span></span><span></span>
          <span></span><span></span><span></span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Content ── -->
  <main class="pv-body">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

          <!-- Tools -->
          <% if (tools.length > 0) { %>
          <div class="pv-card" data-aos="fade-up">
            <div class="pv-card-head">
              <span class="head-icon">🧶</span>
              <h2>الأدوات المطلوبة</h2>
            </div>
            <div class="pv-card-body">
              <table class="tools-tbl">
                <% tools.filter(t => t.name).forEach(function(t) { %>
                <tr>
                  <td><%= t.detail || '' %></td>
                  <td><%= t.name %></td>
                </tr>
                <% }); %>
              </table>
            </div>
          </div>
          <% } %>

          <!-- Abbreviations -->
          <div class="pv-card" data-aos="fade-up" data-aos-delay="60">
            <div class="pv-card-head">
              <span class="head-icon">📋</span>
              <h2>الرموز والاختصارات</h2>
            </div>
            <div class="pv-card-body">
              <div class="abbr-grid-pub">
                <% allAbbrs.forEach(function(a) { %>
                <div class="abbr-item-pub">
                  <span class="abbr-key-pub"><%= a.key %></span>
                  <span class="abbr-val-pub"><%= a.val %></span>
                </div>
                <% }); %>
              </div>
            </div>
          </div>

          <!-- Pattern parts -->
          <% if (parts.length > 0) { %>
          <div class="pv-card" data-aos="fade-up" data-aos-delay="120">
            <div class="pv-card-head">
              <span class="head-icon">✂️</span>
              <h2>خطوات الباترن</h2>
            </div>
            <div class="pv-card-body">
              <% parts.forEach(function(p, i) { %>
                <% if (i > 0) { %>
                  <div class="pv-divider"><span>🤍</span></div>
                <% } %>
                <div class="part-heading"><%= p.name || '' %></div>
                <div class="part-card">
                  <code><%= p.code || '' %></code>
                </div>
                <% if (p.note) { %>
                  <div class="part-note">
                    <span class="note-ico">⭐</span>
                    <%= p.note %>
                  </div>
                <% } %>
              <% }); %>
            </div>
          </div>
          <% } %>

          <!-- Footer brand strip -->
          <div style="text-align:center;padding:20px 0 8px;">
            <div style="font-family:'Playfair Display',serif;font-style:italic;
                        font-size:1.2rem;color:var(--mauve);letter-spacing:2px;">croshim</div>
            <div style="font-family:'Lato',sans-serif;font-size:.6rem;letter-spacing:4px;
                        text-transform:uppercase;color:var(--deep-rose);margin-top:2px;">
              crochet with heart
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>
</body>
</html>
