<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Croshim Studio | تقييم وتحسين الباترن</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/request.css">

  <style>
    .upload-area {
      border: 2.5px dashed #d8c8be;
      border-radius: 14px;
      padding: 2.5rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      background: #faf9f7;
    }
    .upload-area:hover,
    .upload-area.dragover {
      border-color: var(--accent, #c97c5d);
      background: #fdf6f0;
    }
    .upload-area i {
      font-size: 2.5rem;
      color: #d8c8be;
      margin-bottom: 0.75rem;
      display: block;
    }
    .upload-area.has-file i { color: var(--accent, #c97c5d); }
    .upload-filename {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--accent, #c97c5d);
      margin-top: 0.4rem;
    }
    .eval-section {
      background: #f5f9ff;
      border: 1px solid #d0e3f5;
      border-radius: 14px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .eval-section-title {
      font-size: 1rem;
      font-weight: 800;
      color: #2d6aa0;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .improved-section {
      background: #fff;
      border: 1px solid #f0ede9;
      border-radius: 14px;
      padding: 1.5rem;
    }
    .improved-section-title {
      font-size: 1rem;
      font-weight: 800;
      color: var(--accent, #c97c5d);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  </style>
</head>

<body>

  <%- include("../partials/navbar") %>

  <main class="request-page">
    <div class="container">

      <header class="page-header" data-aos="fade-up">
        <div class="request-header-icon">
          <i class="fas fa-file-medical-alt"></i>
        </div>
        <h1 class="request-title">تقييم وتحسين الباترن</h1>
        <p class="request-subtitle">
          ارفع ملف PDF باترن الكروشيه وسيقوم الذكاء الاصطناعي بتقييمه وإنشاء نسخة محسّنة منه
        </p>
      </header>

      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">

          <!-- FORM CARD -->
          <div class="request-card" id="evalFormCard" data-aos="fade-up" data-aos-delay="100">
            <div id="evalFormError" class="alert alert-danger" style="display:none;"></div>

            <input type="hidden" id="evalCsrfToken" value="<%= csrfToken %>">

            <!-- Upload Area -->
            <div class="form-group">
              <label>ملف الباترن (PDF) <span class="required-star">*</span></label>
              <div class="upload-area" id="uploadArea" onclick="document.getElementById('pdfFileInput').click()">
                <i class="fas fa-file-pdf" id="uploadIcon"></i>
                <p class="mb-1" style="font-weight:600; color:#888;" id="uploadPrompt">اضغط هنا لاختيار ملف PDF</p>
                <p style="font-size:0.8rem; color:#aaa;">الحد الأقصى للحجم: 10 ميجابايت</p>
                <p class="upload-filename" id="uploadFilename" style="display:none;"></p>
              </div>
              <input type="file" id="pdfFileInput" accept="application/pdf" style="display:none;">
            </div>

            <button type="button" class="btn request-submit-btn btn-block" id="evalBtn" disabled>
              <i class="fas fa-robot"></i>
              تقييم وتحسين الباترن بالذكاء الاصطناعي
            </button>

            <div class="text-center mt-3">
              <a href="/my_evaluations" style="font-size:0.88rem; color:var(--accent,#c97c5d);">
                <i class="fas fa-history"></i>
                عرض تقييماتي السابقة
              </a>
            </div>
          </div>

          <!-- LOADING CARD -->
          <div class="request-card loading-card" id="evalLoadingCard" style="display:none;" data-aos="fade-up">
            <div class="loading-inner">
              <div class="loading-spinner">
                <div class="spinner-dot"></div>
                <div class="spinner-dot"></div>
                <div class="spinner-dot"></div>
              </div>
              <p class="loading-text">يقرأ الذكاء الاصطناعي الباترن ويحلله...</p>
              <p class="loading-sub">قد يستغرق ذلك 30 ثانية أو أكثر</p>
            </div>
          </div>

          <!-- RESULT CARD -->
          <div id="evalResultCard" style="display:none;" data-aos="fade-up">

            <!-- Result header -->
            <div class="result-card mb-3" style="padding:1.25rem 1.75rem;">
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                  <div class="result-badge mb-1">
                    <i class="fas fa-robot"></i>
                    نتيجة التقييم
                  </div>
                  <h2 class="result-title" id="evalResultTitle" style="font-size:1.15rem; margin:0;"></h2>
                </div>
                <div class="result-actions">
                  <a class="btn result-action-btn pdf-download-btn" id="evalDownloadBtn" style="display:none;" target="_blank" rel="noopener noreferrer">
                    <i class="fas fa-file-pdf"></i><span>تحميل PDF المحسّن</span>
                  </a>
                  <button class="btn result-action-btn" id="evalCopyBtn">
                    <i class="fas fa-copy"></i><span>نسخ الكل</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- Evaluation section -->
            <div class="eval-section" id="evalSection">
              <div class="eval-section-title">
                <i class="fas fa-clipboard-check"></i>
                تقييم الباترن الأصلي
              </div>
              <div id="evalContent" class="result-body" style="padding:0;"></div>
            </div>

            <!-- Improved pattern section -->
            <div class="improved-section">
              <div class="improved-section-title">
                <i class="fas fa-magic"></i>
                الباترن المحسّن
              </div>
              <div id="improvedContent" class="result-body" style="padding:0;"></div>
            </div>

            <div class="result-footer mt-3" style="background:transparent; border:none; padding:0.5rem 0 2rem;">
              <button class="btn new-request-btn" id="evalNewBtn">
                <i class="fas fa-redo-alt"></i>
                تقييم باترن جديد
              </button>
              <p class="result-disclaimer">
                <i class="fas fa-info-circle"></i>
                راجع دائماً عدد الغرز قبل البدء بالتنفيذ.
              </p>
            </div>

          </div>

        </div>
      </div>

    </div>
  </main>

  <%- include("../partials/footer") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>



  <script>
  (function () {
    var fileInput    = document.getElementById('pdfFileInput');
    var uploadArea   = document.getElementById('uploadArea');
    var uploadIcon   = document.getElementById('uploadIcon');
    var uploadPrompt = document.getElementById('uploadPrompt');
    var uploadFilename = document.getElementById('uploadFilename');
    var evalBtn      = document.getElementById('evalBtn');
    var formCard     = document.getElementById('evalFormCard');
    var loadingCard  = document.getElementById('evalLoadingCard');
    var resultCard   = document.getElementById('evalResultCard');
    var formError    = document.getElementById('evalFormError');
    var resultTitle  = document.getElementById('evalResultTitle');
    var evalContent  = document.getElementById('evalContent');
    var improvedContent = document.getElementById('improvedContent');
    var copyBtn      = document.getElementById('evalCopyBtn');
    var downloadBtn  = document.getElementById('evalDownloadBtn');
    var newBtn       = document.getElementById('evalNewBtn');
    var rawResult    = '';
    var selectedFile = null;

    marked.setOptions({ breaks: true, gfm: true });

    // Drag-and-drop
    uploadArea.addEventListener('dragover', function (e) {
      e.preventDefault();
      uploadArea.classList.add('dragover');
    });
    uploadArea.addEventListener('dragleave', function () {
      uploadArea.classList.remove('dragover');
    });
    uploadArea.addEventListener('drop', function (e) {
      e.preventDefault();
      uploadArea.classList.remove('dragover');
      var file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });

    fileInput.addEventListener('change', function () {
      if (this.files[0]) handleFile(this.files[0]);
    });

    function handleFile(file) {
      if (file.type !== 'application/pdf') {
        formError.textContent = 'يُقبل ملف PDF فقط.';
        formError.style.display = 'block';
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        formError.textContent = 'حجم الملف يتجاوز 10 ميجابايت.';
        formError.style.display = 'block';
        return;
      }
      formError.style.display = 'none';
      selectedFile = file;
      uploadArea.classList.add('has-file');
      uploadPrompt.textContent = 'تم اختيار الملف:';
      uploadFilename.textContent = file.name;
      uploadFilename.style.display = 'block';
      evalBtn.disabled = false;
    }

    evalBtn.addEventListener('click', function () {
      if (!selectedFile) return;
      formError.style.display = 'none';

      var reader = new FileReader();
      reader.onload = function (e) {
        // Strip "data:application/pdf;base64," prefix
        var base64 = e.target.result.split(',')[1];

        formCard.style.display    = 'none';
        loadingCard.style.display = '';
        resultCard.style.display  = 'none';

        fetch('/api/evaluate_pattern', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.getElementById('evalCsrfToken').value,
          },
          body: JSON.stringify({
            pdf_base64: base64,
            filename:   selectedFile.name,
          }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            loadingCard.style.display = 'none';

            if (data.error) {
              formCard.style.display = '';
              formError.textContent = data.error;
              formError.style.display = 'block';
              return;
            }

            rawResult = data.result;
            resultTitle.textContent = 'تقييم: ' + selectedFile.name;

            // Split result into evaluation + improved sections
            var splitIdx = data.result.indexOf('## ✨');
            if (splitIdx !== -1) {
              var evalPart     = data.result.substring(0, splitIdx).replace(/^## 📋[^\n]*\n/, '').trim();
              var improvedPart = data.result.substring(splitIdx);
              evalContent.innerHTML     = marked.parse(evalPart);
              improvedContent.innerHTML = marked.parse(improvedPart);
            } else {
              evalContent.innerHTML     = '';
              improvedContent.innerHTML = marked.parse(data.result);
            }

            if (data.pdf_url) {
              downloadBtn.href = data.pdf_url;
              downloadBtn.style.display = '';
            }

            resultCard.style.display = '';
            resultCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
          })
          .catch(function () {
            loadingCard.style.display = 'none';
            formCard.style.display    = '';
            formError.textContent = 'حدث خطأ في الاتصال. يرجى المحاولة مجدداً.';
            formError.style.display = 'block';
          });
      };
      reader.readAsDataURL(selectedFile);
    });

    copyBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(rawResult).then(function () {
        copyBtn.innerHTML = '<i class="fas fa-check"></i><span>تم النسخ!</span>';
        setTimeout(function () {
          copyBtn.innerHTML = '<i class="fas fa-copy"></i><span>نسخ الكل</span>';
        }, 2000);
      });
    });

    newBtn.addEventListener('click', function () {
      resultCard.style.display  = 'none';
      formCard.style.display    = '';
      selectedFile = null;
      fileInput.value = '';
      uploadArea.classList.remove('has-file');
      uploadPrompt.textContent = 'اضغط هنا لاختيار ملف PDF';
      uploadFilename.style.display = 'none';
      evalBtn.disabled = true;
      downloadBtn.style.display = 'none';
      formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();
  </script>

</body>
</html>
