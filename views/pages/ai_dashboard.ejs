<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Crochet Hub | باترناتي بالذكاء الاصطناعي</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/products.css">
  <link rel="stylesheet" href="/css/pages/request.css">
</head>

<body>

  <%- include("../partials/navbar") %>

  <main class="products-page">
    <div class="container">

      <!-- ALERTS -->
      <% if (success_message) { %>
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
          <strong>تم بنجاح!</strong> <%= success_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>
      <% if (error_message) { %>
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
          <strong>خطأ!</strong> <%= error_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>

      <!-- WELCOME BANNER -->
      <div class="welcome-banner" data-aos="fade-up">
        <div class="welcome-info">
          <div class="welcome-avatar">
            <i class="fas fa-magic"></i>
          </div>
          <div>
            <h2 class="welcome-name">
              أهلاً، <%= currentUser.firstName %> <%= currentUser.lastName %>
            </h2>
            <p class="welcome-sub">باترناتك المنشأة بالذكاء الاصطناعي</p>
          </div>
        </div>
        <div class="welcome-stat">
          <span class="stat-count"><%= ai_products ? ai_products.length : 0 %></span>
          <span class="stat-label">باترن</span>
        </div>
      </div>

      <!-- PAGE HEADER -->
      <header class="page-header" data-aos="fade-up">
        <h1 class="products-title">باترناتي</h1>
        <p class="products-subtitle">جميع الباترنات التي أنشأتها بالذكاء الاصطناعي</p>
      </header>

      <!-- NEW PATTERN BUTTON -->
      <div class="text-center mb-4" data-aos="fade-up">
        <button class="btn request-submit-btn px-4" data-toggle="modal" data-target="#pattern_ai">
          <i class="fas fa-magic"></i>
          إنشاء باترن جديد
        </button>
      </div>

      <!-- PATTERNS GRID -->
      <div class="row">

        <% if (ai_products && ai_products.length > 0) { %>

          <% ai_products.forEach(function(item, index) { %>

            <div class="col-12 col-sm-6 col-md-4 mb-4" data-aos="fade-up" data-aos-delay="<%= index * 60 %>">
              <article class="card product-card ai-pattern-card">

                <div class="product-header">
                  <div class="ai-pattern-badge">
                    <i class="fas fa-magic"></i> ذكاء اصطناعي
                  </div>
                  <span class="label-title">اسم الباترن</span>
                  <h2 class="product-name"><%= item.product_name %></h2>
                </div>

                <div class="product-body">

                  <div class="product-meta">
                    <span class="label-title">نوع المنتج</span>
                    <p class="product-description"><%= item.product_type %></p>
                  </div>

                  <div class="product-meta">
                    <span class="label-title">وصف الطلب</span>
                    <p class="product-description ai-desc">
                      <%= item.product_description %>
                    </p>
                  </div>

                  <% if (item.colors) { %>
                  <div class="product-meta">
                    <span class="label-title">الألوان</span>
                    <p class="product-description"><%= item.colors %></p>
                  </div>
                  <% } %>

                  <div class="product-meta">
                    <span class="label-title">تاريخ الإنشاء</span>
                    <p class="product-description ai-date">
                      <i class="fas fa-calendar-alt" style="margin-left:4px;"></i>
                      <%= new Date(item.createdAt).toLocaleDateString('ar-SA') %>
                    </p>
                  </div>

                  <div class="product-meta">
                    <span class="label-title">ملف الباترن</span>
                    <% if (item.pdf_path) { %>
                      <a href="<%= item.pdf_path %>" target="_blank" rel="noopener noreferrer"
                        class="btn pdf-btn" style="font-size:0.85rem; padding:0.4rem 0.9rem;">
                        <i class="fas fa-file-pdf"></i>
                        تحميل الباترن PDF
                      </a>
                    <% } else { %>
                      <div class="no-file">
                        <i class="far fa-folder-open"></i>
                        لا يوجد ملف
                      </div>
                    <% } %>
                  </div>

                </div>

              </article>
            </div>

          <% }) %>

        <% } else { %>

          <div class="col-12" data-aos="fade-up">
            <div class="empty-state">
              <i class="fas fa-magic empty-icon"></i>
              <h5>لا توجد باترنات حالياً</h5>
              <p>أنشئ باترنك الأول بالذكاء الاصطناعي الآن!</p>
              <button class="btn pdf-btn mt-3" data-toggle="modal" data-target="#pattern_ai">
                <i class="fas fa-magic"></i> إنشاء باترن جديد
              </button>
            </div>
          </div>

        <% } %>

      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>

  <!-- AI PATTERN MODAL -->
  <%- include("../partials/request_pattern") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>



</body>
</html>
