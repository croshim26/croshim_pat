<!DOCTYPE html>
<html lang="ar" dir="rtl">


<%- include("../layouts/head", { pageTitle: "Crochet Hub | الصفحة الرئيسية" }) %>

<body>

  <section id="title" class="hero">

    <%- include("../partials/navbar") %>

    <div class="container hero-container">

      <%- include("../partials/alerts", {
        error_message,
        success_message
      }) %>

      <div class="row hero-row" data-aos="fade-up">

        <div class="col-lg-6 hero-copy">
          <h1 class="hero-title">Crochet Hub</h1>

          <p class="hero-subtitle">
            منصة كروشيه تجمع كل شيء في مكان واحد:
            دورات تعليمية، ملفات باترن PDF، ومنتجات كروشيه مع تفاصيلها.
            هدفنا تسهيل التعلم، البيع، والاحتراف من أول غرزة إلى آخر عقدة.
          </p>
        </div>

        <div class="col-lg-6 hero-cta">
          <section id="products-section" class="hero-search">
            <div class="Searcher-box">

              <a class="icon_search" href="/all_products" aria-label="عرض المنتجات">
                <i class="fas fa-shopping-bag"></i>
                <span class="icon_search_text">عرض المنتجات</span>
              </a>

              <div class="hero-search-text">
                <h3 class="h3_search">المنتجات والباترن</h3>
                <p class="P1_search">تصفح منتجات الكروشيه وملفات PDF الخاصة بها</p>
              </div>

            </div>
          </section>
        </div>

      </div>
    </div>

  </section>

  <!-- FEATURES SECTION -->
  <section class="features-section" data-aos="fade-up">
    <div class="container">
      <h2 class="section-title">لماذا Crochet Hub؟</h2>
      <div class="row features-row">

        <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="0">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-file-pdf"></i>
            </div>
            <h3 class="feature-title">ملفات باترن PDF</h3>
            <p class="feature-desc">
              أضف وشارك ملفات الباترن بصيغة PDF مباشرةً مع كل منتج، ليتمكن الجميع من الوصول إليها بسهولة.
            </p>
          </div>
        </div>

        <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-store"></i>
            </div>
            <h3 class="feature-title">متجر منتجاتك</h3>
            <p class="feature-desc">
              أنشئ حسابك وابدأ بعرض منتجات الكروشيه الخاصة بك على المنصة وصولاً إلى أوسع شريحة من المهتمين.
            </p>
          </div>
        </div>

        <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
          <div class="feature-card">
            <div class="feature-icon">
              <i class="fas fa-users"></i>
            </div>
            <h3 class="feature-title">مجتمع الكروشيه</h3>
            <p class="feature-desc">
              تواصل مع محترفين وهواة الكروشيه، واكتشف إبداعاتهم من منتجات وأعمال يدوية مميزة.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ABOUT SECTION -->
  <section id="about" class="about-section" data-aos="fade-up">
    <div class="container">
      <h2 class="section-title">عن المنصة</h2>
      <p class="section-text">
        Crochet Hub منصة تساعد المهتمين بالكروشيه على مشاركة المنتجات، عرض ملفات الباترن، وتسهيل الوصول إلى المحتوى التعليمي والمنتجات في مكان واحد.
      </p>
    </div>
  </section>

  <!-- ADD PRODUCT MODAL -->
  <%- include("../partials/add_product") %>

  <%- include("../partials/footer") %>

  <%- include("../partials/login-modal") %>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"
    integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n"
    crossorigin="anonymous"></script>

  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"
    integrity="sha384-JjSmVgyd0p3pXB1rRibZUAYoIIy6OrQ6VrjIEaFf/nJGzIxFDsf4x0xIM+B07jRM"
    crossorigin="anonymous"></script>

  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>

  <script>
    AOS.init({ once: true, duration: 600 });
  </script>

</body>
</html>
