<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Croshim Studio | كلمة مرور جديدة</title>

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/auth.css">
</head>

<body>

  <main class="auth-page">
    <div class="auth-card" style="max-width: 480px;">

      <div class="auth-card-header">
        <a href="/" class="auth-brand">
          <span class="logo-badge">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 2 L10 13 C10 16.5 7 17.5 5.2 16 C3.5 14.5 4 12.5 6.2 12.2" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="10" cy="2" r="1.4" fill="white"/>
            </svg>
          </span>
          <span class="logo-name">Croshim Studio</span>
        </a>
        <h1>كلمة مرور جديدة</h1>
        <p>اختر كلمة مرور قوية لحسابك</p>
      </div>

      <% if (error_message) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="fas fa-exclamation-circle ml-1"></i>
          <%= error_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>

      <form action="/reset/<%= token %>" method="POST" id="resetForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label for="password">كلمة المرور الجديدة</label>
          <div class="input-wrapper">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              id="password"
              name="password"
              class="form-control auth-input"
              placeholder="6 أحرف على الأقل"
              minlength="6"
              required
              autofocus
            >
          </div>
        </div>

        <div class="form-group">
          <label for="confirm_password">تأكيد كلمة المرور</label>
          <div class="input-wrapper">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              id="confirm_password"
              name="confirm_password"
              class="form-control auth-input"
              placeholder="أعد كتابة كلمة المرور"
              minlength="6"
              required
            >
          </div>
          <small id="matchMsg" style="display:none; font-size:.82rem; margin-top:.3rem; display:block;"></small>
        </div>

        <button type="submit" class="btn auth-submit-btn btn-block" id="submitBtn">
          <i class="fas fa-check ml-1"></i>
          حفظ كلمة المرور الجديدة
        </button>
      </form>

    </div>
  </main>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>

  <script>
    var pw  = document.getElementById('password');
    var cpw = document.getElementById('confirm_password');
    var msg = document.getElementById('matchMsg');
    var btn = document.getElementById('submitBtn');

    function checkMatch() {
      if (!cpw.value) { msg.style.display = 'none'; return; }
      if (pw.value === cpw.value) {
        msg.style.display = 'block';
        msg.style.color   = '#16a34a';
        msg.textContent   = '✓ كلمتا المرور متطابقتان';
        btn.disabled = false;
      } else {
        msg.style.display = 'block';
        msg.style.color   = '#dc2626';
        msg.textContent   = '✗ كلمتا المرور غير متطابقتين';
        btn.disabled = true;
      }
    }

    pw.addEventListener('input', checkMatch);
    cpw.addEventListener('input', checkMatch);
  </script>

</body>
</html>
