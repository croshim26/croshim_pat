<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Croshim Studio | جميع المنتجات</title>

  <!-- External CSS -->
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

  <!-- App CSS -->
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/products.css">
</head>

<body>

  <!-- NAVBAR -->
  <%- include("../partials/navbar") %>

  <!-- PRODUCTS PAGE -->
  <main class="products-page">
    <div class="container">

      <!-- ALERTS -->
      <% if (success_message) { %>
        <div class="alert alert-success alert-dismissible fade show hero-alert mt-3" role="alert">
          <strong>تم بنجاح!</strong> <%= success_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>
      <% if (error_message) { %>
        <div class="alert alert-danger alert-dismissible fade show hero-alert mt-3" role="alert">
          <strong>خطأ!</strong> <%= error_message %>
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      <% } %>

      <!-- PAGE HEADER -->
      <header class="page-header" data-aos="fade-up">
        <h1 class="products-title">جميع المنتجات</h1>
        <p class="products-subtitle">
          تصفح منتجات الكروشيه وملفات الباترن المتاحة
        </p>
      </header>

      <!-- SEARCH BAR -->
      <% if (products && products.length > 0) { %>
        <div class="search-wrap" data-aos="fade-up">
          <div class="search-input-wrapper">
            <i class="fas fa-search search-icon"></i>
            <input
              type="text"
              id="productSearch"
              class="form-control search-input"
              placeholder="ابحث عن منتج باسمه أو وصفه..."
              autocomplete="off"
            >
          </div>
          <span id="searchCount" class="search-count"><%= products.length %> منتج</span>
        </div>
      <% } %>

      <!-- PRODUCTS LIST -->
      <div class="row" id="productsGrid">

        <% if (products && products.length > 0) { %>

          <% products.forEach(function(product, index) { %>

            <div class="col-12 col-sm-6 col-md-4 mb-4 product-item"
              data-aos="fade-up"
              data-aos-delay="<%= index * 60 %>"
              data-name="<%= product.product_name.toLowerCase() %>"
              data-desc="<%= product.product_description.toLowerCase() %>"
            >
              <article class="card product-card">

                <div class="product-header">
                  <span class="label-title">اسم المنتج</span>
                  <h2 class="product-name">
                    <%= product.product_name %>
                  </h2>
                </div>

                <div class="product-body">

                  <div class="product-meta">
                    <span class="label-title">اسم العميل</span>
                    <div class="product-owner">
                      <i class="fas fa-user"></i>
                      <span>
                        <%= product.user
                          ? product.user.firstName + " " + product.user.lastName
                          : "غير معروف"
                        %>
                      </span>
                    </div>
                  </div>

                  <div class="product-meta">
                    <span class="label-title">وصف المنتج</span>
                    <p class="product-description">
                      <%= product.product_description %>
                    </p>
                  </div>

                  <div class="product-meta">
                    <span class="label-title">ملف المنتج</span>

                    <% if (product.pdf_path) { %>
                      <a
                        href="<%= product.pdf_path %>"
                        target="_blank"
                        class="btn pdf-btn"
                        rel="noopener noreferrer"
                      >
                        <i class="fas fa-file-pdf"></i>
                        عرض ملف المنتج
                      </a>
                    <% } else { %>
                      <div class="no-file">
                        <i class="far fa-folder-open"></i>
                        لا يوجد ملف للمنتج
                      </div>
                    <% } %>
                  </div>

                </div>
              </article>
            </div>

          <% }) %>

        <% } else { %>

          <div class="col-12" data-aos="fade-up">
            <div class="empty-state">
              <i class="fas fa-box-open empty-icon"></i>
              <h5>لا توجد منتجات حالياً</h5>
              <p>يمكنك إضافة منتج جديد من خلال نموذج الإضافة.</p>
            </div>
          </div>

        <% } %>

        <!-- No search results message -->
        <div class="col-12" id="noSearchResults" style="display:none;">
          <div class="empty-state">
            <i class="fas fa-search empty-icon"></i>
            <h5>لا توجد نتائج</h5>
            <p>لم يُعثر على منتج يطابق بحثك. جرّب كلمة أخرى.</p>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- ADD PRODUCT MODAL -->
  <%- include("../partials/add_product") %>

  <!-- FOOTER -->
  <%- include("../partials/footer") %>

  <%- include("../partials/login-modal") %>

  <!-- JS -->
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script>AOS.init({ once: true, duration: 500 });</script>



  <script>
    (function () {
      var searchInput = document.getElementById('productSearch');
      var searchCount = document.getElementById('searchCount');
      var noResults = document.getElementById('noSearchResults');

      if (!searchInput) return;

      searchInput.addEventListener('input', function () {
        var query = this.value.trim().toLowerCase();
        var items = document.querySelectorAll('.product-item');
        var visible = 0;

        items.forEach(function (item) {
          var name = item.dataset.name || '';
          var desc = item.dataset.desc || '';
          var match = !query || name.includes(query) || desc.includes(query);
          item.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        if (searchCount) searchCount.textContent = visible + ' منتج';
        if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
      });
    })();
  </script>

</body>
</html>
