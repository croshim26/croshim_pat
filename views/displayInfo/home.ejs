<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Crochet Hub | المنتجات</title>

  <!-- Bootstrap + FontAwesome -->
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css"
    integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh"
    crossorigin="anonymous" />
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css" />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>

  <style>
    body{
      font-family: "Cairo", sans-serif;
      background: linear-gradient(135deg, #fdf8f3 0%, #f6f1fb 50%, #fceff4 100%);
      min-height: 100vh;
      color: #0f172a;
    }
    body::before{
      content:"";
      position: fixed;
      inset: 0;
      background-image: radial-gradient(rgba(107,101,173,.05) 1px, transparent 1px);
      background-size: 25px 25px;
      pointer-events: none;
      z-index: 0;
    }

    /* ===== NAVBAR ===== */
    .site-nav{
      position: sticky;
      top: 0;
      z-index: 999;
      background: rgba(255,255,255,.75);
      border-bottom: 1px solid rgba(0,0,0,.06);
      backdrop-filter: blur(12px);
    }
    .site-nav .navbar-brand{
      font-weight: 1000;
      letter-spacing: .2px;
      color: #111827 !important;
      display:flex;
      align-items:center;
      gap:10px;
    }
    .site-nav .navbar-brand::before{
      content:"🧶";
    }

    .site-nav .nav-link{
      color: rgba(15,23,42,.78) !important;
      font-weight: 900;
      padding: .55rem .85rem;
      border-radius: 14px;
      transition: .2s ease;
    }
    .site-nav .nav-link:hover{
      background: rgba(107,101,173,.10);
      transform: translateY(-1px);
    }
    .nav-cta{
      background: linear-gradient(135deg, rgba(107,101,173,.95), rgba(224,138,160,.85));
      color:#fff !important;
      border-radius: 16px;
      box-shadow: 0 12px 30px rgba(0,0,0,.12);
      border: 1px solid rgba(255,255,255,.2);
    }
    .nav-cta:hover{
      filter: brightness(1.05);
    }

    /* ===== YOUR PRODUCTS CSS (same, lightly tuned) ===== */
    .products-wrap {
      padding-top: 2rem;
      padding-bottom: 3rem;
      position: relative;
      z-index: 1;
    }

    .products-title {
      font-weight: 900;
      margin-bottom: 1.5rem;
      color: #1f2937;
    }

    .product-card {
      border: 0;
      border-radius: 18px;
      overflow: hidden;
      background: #ffffff;
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
      transition: all 0.2s ease-in-out;
      height: 100%;
    }

    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    }

    .product-header {
      background: linear-gradient(135deg, rgba(107,101,173,0.15), #ffffff);
      padding: 15px;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      text-align: right;
    }

    .product-name {
      font-weight: 900;
      margin: 0;
      color: #111827;
      font-size: 1.1rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .product-body {
      padding: 15px;
      text-align: right;
    }

    .label-title {
      font-weight: 800;
      color: #374151;
      margin-bottom: 5px;
    }

    .product-description {
      color: #4b5563;
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 15px;
    }

    .pdf-btn {
      border-radius: 12px;
      padding: 8px 12px;
      font-weight: 800;
      background: linear-gradient(135deg, #6b65ad, #e08aa0);
      border: 0;
      box-shadow: 0 12px 25px rgba(0,0,0,.12);
    }
    .pdf-btn:hover{
      filter: brightness(1.05);
      transform: translateY(-1px);
    }

    .no-file {
      color: #6b7280;
      font-weight: 700;
      background: rgba(0,0,0,.04);
      border: 1px dashed rgba(0,0,0,.18);
      padding: 10px 12px;
      border-radius: 12px;
      display: inline-block;
    }

    .details-box {
      margin-top: 12px;
      padding: 12px;
      background: rgba(49,179,163,.08);
      border: 1px solid rgba(49,179,163,.18);
      border-radius: 12px;
      font-size: 0.92rem;
    }

    .details-box ul{
      margin: 0;
      padding-right: 18px;
    }

    .empty-state {
      padding: 30px;
      border-radius: 15px;
      border: 1px dashed rgba(0,0,0,0.2);
      background: #ffffff;
      box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    /* ===== FOOTER ===== */
    .site-footer{
      position: relative;
      z-index: 1;
      padding: 2rem 0 1rem;
      background: rgba(255,255,255,.75);
      border-top: 1px solid rgba(0,0,0,.06);
      backdrop-filter: blur(12px);
    }
    .site-footer .copy{
      margin: 0;
      text-align: center;
      font-weight: 800;
      color: rgba(15,23,42,.6);
    }
  </style>
</head>

<body>

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg site-nav">
    <div class="container">
      <a class="navbar-brand" href="/">Crochet Hub</a>

      <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#mainNav"
        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ml-auto">

          <li class="nav-item">
            <a class="nav-link" href="/">الرئيسية</a>
          </li>

          <li class="nav-item active">
            <a class="nav-link" href="/display_product">المنتجات</a>
          </li>

          <li class="nav-item">
            <a class="nav-link nav-cta" href="#" 
   data-toggle="modal" 
   data-target="#exampleModal3">
   إضافة منتج
</a>
          </li>

          <form id="magic-form" action="/logout" method="POST">
            <input type="hidden" name="_csrf" value=<%=csrfToken%> 
            <input type="text">
    
    </form>

          <li class="nav-item">
            <a href="/logout" class="nav-link" onclick="event.preventDefault();
            document.getElementById('magic-form').submit();"> تسجيل خروج</a>
          </li>



        </ul>
      </div>
    </div>
  </nav>

  <!-- ===== PRODUCTS SECTION ===== -->
  <section class="products-wrap">
    <div class="container">
      <h5 class="products-title">المنتجات</h5>

      <div class="row">

        <% if (products && products.length > 0) { %>
          <% products.forEach(p => { %>

            <div class="col-12 col-sm-6 col-md-4 mb-4">
              <div class="card product-card">

                <div class="product-header">
                  <div class="label-title">اسم المنتج</div>
                  <h5 class="product-name"><%= p.product_name %></h5>
                </div>

                <div class="product-body">

                  <div class="label-title">وصف المنتج</div>
                  <div class="product-description">
                    <%= p.product_description %>
                  </div>

                  <div class="label-title">ملف المنتج</div>

                  <% if (p.pdf_path) { %>
                    <a
                      href="/<%= p.pdf_path %>"
                      target="_blank"
                      class="btn btn-danger pdf-btn"
                      rel="noopener"
                    >
                      <i class="fas fa-file-pdf"></i>
                      عرض ملف المنتج
                    </a>
                  <% } else { %>
                    <div class="no-file">
                      <i class="far fa-folder-open"></i>
                      لا يوجد ملف للمنتج
                    </div>
                  <% } %>

                  <% if (p.pattern && typeof p.pattern === "object") { %>
                    <div class="details-box">
                      <div class="label-title mb-2">تفاصيل إضافية</div>
                      <ul>
                        <% Object.entries(p.pattern).forEach(([key, value]) => { %>
                          <li>
                            <strong><%= key %>:</strong>
                            <%= Array.isArray(value) ? value.join(", ") : value %>
                          </li>
                        <% }) %>
                      </ul>
                    </div>
                  <% } %>

                  <form action="/delete_product/<%= p.id %>" method="POST" style="margin-top:10px;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  
                    <button type="submit" class="btn btn-danger btn-block"
                      onclick="return confirm('هل أنت متأكد من حذف المنتج؟');">
                      حذف المنتج
                    </button>
                  </form>
                  

                </div>

              </div>
            </div>

            

          <% }) %>

        <% } else { %>

          <div class="col-12 text-center">
            <div class="empty-state">
              <h5 style="font-weight:900;">لا توجد منتجات حالياً</h5>
              <p style="margin:0;color:#6b7280;font-weight:700;">يمكنك إضافة منتج جديد من خلال نموذج الإضافة.</p>
            </div>
          </div>

        <% } %>

      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer">
    <div class="container">
      <p class="copy">© Copyright 2027 Crochet Hub</p>
    </div>
  </footer>


  <!-- JS -->
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js">



  
  



document.addEventListener("DOMContentLoaded", function(){

  var sel1 = document.querySelector('#sel1');
  var sel2 = document.querySelector('#sel2');

  if (sel1 && sel2) {

    var options2 = Array.from(sel2.querySelectorAll('option'));

    function giveSelection(selValue) {
      sel2.innerHTML = '';
      options2.forEach(function(option){
        if(option.dataset.option === selValue){
          sel2.appendChild(option);
        }
      });
    }

    giveSelection(sel1.value);

    sel1.addEventListener("change", function(){
      giveSelection(this.value);
    });
  }

});

      
    
    



  </script>
</body>
</html>
<%- include('.././includes/includes_nav/add_product') %>