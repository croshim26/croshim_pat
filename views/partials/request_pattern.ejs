<div class="modal fade" id="pattern_ai" tabindex="-1" role="dialog"
  aria-labelledby="patternModalLabel" aria-hidden="true">

  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content auth-modal">

      <div class="modal-header auth-header">
        <h5 class="modal-title auth-title" id="patternModalLabel">
          <i class="fas fa-magic" style="color:#c97c5d; margin-left:6px;"></i>
          طلب باترن بالذكاء الاصطناعي
        </h5>
        <button type="button" class="close auth-close" data-dismiss="modal">&times;</button>
      </div>

      <!-- FORM SECTION -->
      <div class="modal-body" id="patternFormSection">
        <div id="patternFormError" class="alert alert-danger" style="display:none;"></div>

        <form id="patternForm" novalidate>
          <input type="hidden" id="patternCsrfField" value="<%= csrfToken %>">

          <div class="form-group">
            <label for="pm_product_name">اسم الباترن <span class="required-star">*</span></label>
            <input
              type="text"
              class="form-control request-input"
              id="pm_product_name"
              name="product_name"
              placeholder="مثال: قبعة الشتاء الدافئة"
              required
            >
          </div>

          <div class="form-section">
            <h3 class="form-section-title">
              <i class="fas fa-list-alt"></i>
              تفاصيل الطلب
            </h3>

            <div class="form-group">
              <label for="pm_product_type">نوع المنتج <span class="required-star">*</span></label>
              <select class="form-control request-input" id="pm_product_type" name="product_type" required>
                <option value="" disabled selected>اختر نوع المنتج</option>
                <option value="قبعة">قبعة</option>
                <option value="وسادة">وسادة</option>
                <option value="حقيبة">حقيبة</option>
                <option value="بطانية">بطانية</option>
                <option value="ملابس أطفال">ملابس أطفال</option>
                <option value="إكسسوار">إكسسوار</option>
                <option value="دمية">دمية / أميغورومي</option>
                <option value="شال">شال أو وشاح</option>
                <option value="ديكور منزلي">ديكور منزلي</option>
                <option value="أخرى">أخرى</option>
              </select>
            </div>

            <div class="form-group">
              <label for="pm_description">
                وصف المنتج المطلوب <span class="required-star">*</span>
                <span class="field-hint">كلما كانت التفاصيل أكثر، كان الباترن أدق</span>
              </label>
              <textarea
                class="form-control request-input"
                id="pm_description"
                name="product_description"
                rows="4"
                placeholder="مثال: قبعة دافئة للشتاء بشكل بسيط، مناسبة للبالغين، بحافة مضلعة من الأسفل..."
                required
              ></textarea>
            </div>

            <div class="form-row">
              <div class="form-group col-12 col-md-6">
                <label for="pm_colors">الألوان المفضلة <span class="optional-label">(اختياري)</span></label>
                <input
                  type="text"
                  class="form-control request-input"
                  id="pm_colors"
                  name="colors"
                  placeholder="مثال: أبيض، بيج، وردي فاتح"
                >
              </div>

              <div class="form-group col-12 col-md-6">
                <label for="pm_size_notes">المقاس أو الأبعاد <span class="optional-label">(اختياري)</span></label>
                <input
                  type="text"
                  class="form-control request-input"
                  id="pm_size_notes"
                  name="size_notes"
                  placeholder="مثال: مقاس للبالغين، 40×40 سم"
                >
              </div>
            </div>

            <div class="form-group">
              <label for="pm_additional_notes">ملاحظات إضافية <span class="optional-label">(اختياري)</span></label>
              <textarea
                class="form-control request-input"
                id="pm_additional_notes"
                name="additional_notes"
                rows="2"
                placeholder="مستوى الصعوبة المفضل، نوع الخيط، أي تفاصيل خاصة..."
              ></textarea>
            </div>
          </div>

          <button type="submit" class="btn request-submit-btn btn-block" id="pm_generateBtn">
            <i class="fas fa-magic"></i>
            إنشاء الباترن بالذكاء الاصطناعي
          </button>
        </form>
      </div>

      <!-- LOADING SECTION -->
      <div class="modal-body text-center py-5" id="patternLoadingSection" style="display:none;">
        <div class="loading-spinner justify-content-center mb-3">
          <div class="spinner-dot"></div>
          <div class="spinner-dot"></div>
          <div class="spinner-dot"></div>
        </div>
        <p class="loading-text">يقوم الذكاء الاصطناعي بإنشاء باترنك...</p>
        <p class="loading-sub">قد يستغرق ذلك بضع ثوانٍ</p>
      </div>

      <!-- RESULT SECTION -->
      <div id="patternResultSection" style="display:none;">
        <div class="result-header px-4 pt-3 pb-2" style="background:#fdf6f0; border-bottom:1px solid #f0ede9;">
          <div>
            <div class="result-badge mb-1">
              <i class="fas fa-magic"></i>
              باترن منشأ بالذكاء الاصطناعي
            </div>
            <h2 class="result-title" id="pm_resultTitle" style="font-size:1.2rem;"></h2>
          </div>
          <div class="result-actions mt-2">
            <a class="btn result-action-btn pdf-download-btn" id="pm_downloadBtn" style="display:none;" target="_blank" rel="noopener noreferrer">
              <i class="fas fa-file-pdf"></i><span>تحميل PDF</span>
            </a>
            <button class="btn result-action-btn" id="pm_copyBtn">
              <i class="fas fa-copy"></i><span>نسخ</span>
            </button>
            <button class="btn result-action-btn" id="pm_printBtn">
              <i class="fas fa-print"></i><span>طباعة</span>
            </button>
          </div>
        </div>

        <div class="result-body px-4 py-3" id="pm_patternOutput"
          style="max-height:50vh; overflow-y:auto; direction:rtl;"></div>

        <div class="result-footer px-4 py-3" style="background:#faf9f7; border-top:1px solid #f0ede9;">
          <button class="btn new-request-btn" id="pm_newRequestBtn">
            <i class="fas fa-redo-alt"></i>
            طلب باترن جديد
          </button>
          <p class="result-disclaimer mt-2 mb-0">
            <i class="fas fa-info-circle"></i>
            تأكد دائماً من عدد الغرز أثناء التنفيذ.
          </p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function () {
  var form          = document.getElementById('patternForm');
  var formSection   = document.getElementById('patternFormSection');
  var loadingSection= document.getElementById('patternLoadingSection');
  var resultSection = document.getElementById('patternResultSection');
  var formError     = document.getElementById('patternFormError');
  var resultTitle   = document.getElementById('pm_resultTitle');
  var patternOutput = document.getElementById('pm_patternOutput');
  var copyBtn       = document.getElementById('pm_copyBtn');
  var printBtn      = document.getElementById('pm_printBtn');
  var downloadBtn   = document.getElementById('pm_downloadBtn');
  var newRequestBtn = document.getElementById('pm_newRequestBtn');
  var rawPatternText = '';

  if (typeof marked !== 'undefined') {
    marked.setOptions({ breaks: true, gfm: true });
  }

  function showForm() {
    formSection.style.display    = '';
    loadingSection.style.display = 'none';
    resultSection.style.display  = 'none';
  }

  function showLoading() {
    formSection.style.display    = 'none';
    loadingSection.style.display = '';
    resultSection.style.display  = 'none';
  }

  function showResult() {
    formSection.style.display    = 'none';
    loadingSection.style.display = 'none';
    resultSection.style.display  = '';
  }

  // Reset to form when modal is closed
  document.getElementById('pattern_ai').addEventListener('hidden.bs.modal', showForm);
  document.getElementById('pattern_ai').addEventListener('hidden.bs.modal', function () {
    form.reset();
    formError.style.display = 'none';
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    formError.style.display = 'none';

    var productName = document.getElementById('pm_product_name').value.trim();
    var productType = document.getElementById('pm_product_type').value;
    var product_description = document.getElementById('pm_description').value.trim();

    if (!productName || !productType || !product_description) {
      formError.textContent = 'يرجى تعبئة جميع الحقول الإلزامية.';
      formError.style.display = 'block';
      return;
    }

    showLoading();

    var payload = {
      product_name:     productName,
      product_type:     productType,
      product_description:      product_description,
      colors:           document.getElementById('pm_colors').value.trim(),
      size_notes:       document.getElementById('pm_size_notes').value.trim(),
      additional_notes: document.getElementById('pm_additional_notes').value.trim(),
    };

    fetch('/api/generate_pattern', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.getElementById('patternCsrfField').value,
      },
      body: JSON.stringify(payload),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) {
          showForm();
          formError.textContent = data.error;
          formError.style.display = 'block';
          return;
        }
        rawPatternText = data.pattern;
        resultTitle.textContent = 'باترن ' + productName;
        patternOutput.innerHTML = (typeof marked !== 'undefined')
          ? marked.parse(data.pattern)
          : data.pattern.replace(/\n/g, '<br>');
        if (data.pdf_url) {
          downloadBtn.href = data.pdf_url;
          downloadBtn.style.display = '';
        } else {
          downloadBtn.style.display = 'none';
        }
        showResult();
      })
      .catch(function () {
        showForm();
        formError.textContent = 'حدث خطأ في الاتصال. يرجى المحاولة مجدداً.';
        formError.style.display = 'block';
      });
  });

  copyBtn.addEventListener('click', function () {
    navigator.clipboard.writeText(rawPatternText).then(function () {
      copyBtn.innerHTML = '<i class="fas fa-check"></i><span>تم النسخ!</span>';
      setTimeout(function () {
        copyBtn.innerHTML = '<i class="fas fa-copy"></i><span>نسخ</span>';
      }, 2000);
    });
  });

  printBtn.addEventListener('click', function () {
    var win = window.open('', '_blank');
    win.document.write(
      '<html dir="rtl"><head><meta charset="utf-8"><title>باترن كروشيه</title>' +
      '<style>body{font-family:Arial,sans-serif;padding:2rem;line-height:1.8;direction:rtl;}' +
      'h2,h3{color:#c97c5d;}</style></head><body>' +
      patternOutput.innerHTML + '</body></html>'
    );
    win.document.close();
    win.print();
  });

  newRequestBtn.addEventListener('click', function () {
    form.reset();
    showForm();
  });
})();
</script>
