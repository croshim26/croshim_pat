<!-- CSRF token for JS fetch calls -->
<script>window.__csrfToken = '<%= csrfToken %>';</script>

<!-- Chat stylesheet -->
<link rel="stylesheet" href="/css/chat.css">

<!-- Floating action button -->
<button class="chat-fab" id="chatFab" aria-label="فتح المساعد">
  <span class="chat-fab-icon-open">🧶</span>
  <span class="chat-fab-icon-close"><i class="fas fa-times"></i></span>
  <span class="chat-fab-badge" id="chatBadge"></span>
</button>

<!-- Chat panel -->
<div class="chat-panel" id="chatPanel" role="dialog" aria-label="مساعد Crochet Hub">

  <div class="chat-header">
    <div class="chat-header-info">
      <div class="chat-avatar">🧶</div>
      <div>
        <p class="chat-header-title">مساعد Crochet Hub</p>
        <p class="chat-header-sub">اسألني عن الكروشيه والباترن</p>
      </div>
    </div>
    <button class="chat-close-btn" id="chatCloseBtn" aria-label="إغلاق">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="chat-messages" id="chatMessages">
    <!-- Welcome message -->
    <div class="chat-msg bot">
      <div class="chat-msg-icon"><i class="fas fa-yarn"></i></div>
      <div class="chat-bubble">
        أهلاً! أنا مساعد Crochet Hub 🧶<br>
        يمكنني مساعدتك في فهم الباترن، اختيار الغرز، معرفة أنواع الخيط، وحل مشاكل الكروشيه.<br>
        ما الذي تريد معرفته؟
      </div>
    </div>
  </div>

  <div class="chat-input-area">
    <textarea
      id="chatInput"
      class="chat-input"
      placeholder="اكتب سؤالك هنا..."
      rows="1"
      dir="auto"
      maxlength="2000"
    ></textarea>
    <button class="chat-send-btn" id="chatSendBtn" aria-label="إرسال">
      <i class="fas fa-paper-plane"></i>
    </button>
  </div>

</div>

<script src="/js/chat.js"></script>
