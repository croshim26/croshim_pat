<% if (error_message) { %>
  <div class="alert alert-danger alert-dismissible fade show hero-alert" role="alert">
    <strong>خطأ!</strong> <%= error_message %>
    <button type="button" class="close" data-dismiss="alert">&times;</button>
  </div>
<% } %>

<% if (success_message) { %>
  <div class="alert alert-success alert-dismissible fade show hero-alert" role="alert">
    <strong>تم بنجاح!</strong> <%= success_message %>
    <button type="button" class="close" data-dismiss="alert">&times;</button>
  </div>
<% } %>