<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>المستخدمون — Croshim Studio</title>
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/pages/admin.css">
</head>
<body>
<div class="admin-shell">

  <%- include('./_sidebar', { currentPage: 'users' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-topbar-title">المستخدمون</h1>
      <span class="admin-topbar-user">
        <i class="fas fa-user-shield"></i>
        <%= adminUser.firstName %> <%= adminUser.lastName %>
      </span>
    </div>

    <div class="admin-content">

      <% if (successMessage) { %>
        <div class="admin-alert admin-alert-success"><i class="fas fa-check-circle"></i> <%= successMessage %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="admin-alert admin-alert-error"><i class="fas fa-exclamation-circle"></i> <%= errorMessage %></div>
      <% } %>

      <div class="admin-table-wrap">
        <div class="admin-table-head">
          <h2 class="admin-table-title">
            <i class="fas fa-users"></i>
            قائمة المستخدمين
            <span class="admin-count"><%= users.length %></span>
          </h2>
        </div>

        <% if (users.length === 0) { %>
          <div class="admin-empty">
            <i class="fas fa-users"></i>
            لا يوجد مستخدمون بعد.
          </div>
        <% } else { %>
        <div style="overflow-x:auto;">
          <table class="atbl">
            <thead>
              <tr>
                <th>#</th>
                <th>الاسم</th>
                <th>البريد الإلكتروني</th>
                <th>الهاتف</th>
                <th>الصلاحية</th>
                <th>تاريخ التسجيل</th>
                <th>إجراءات</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(user) { %>
              <tr>
                <td><%= user.id %></td>
                <td><%= user.firstName %> <%= user.lastName %></td>
                <td><%= user.email %></td>
                <td><%= user.phone || '—' %></td>
                <td>
                  <% if (user.is_admin) { %>
                    <span class="badge-admin">مدير</span>
                  <% } else { %>
                    <span class="badge-user">مستخدم</span>
                  <% } %>
                </td>
                <td><%= new Date(user.createdAt).toLocaleDateString('ar-SA') %></td>
                <td style="white-space:nowrap;display:flex;gap:6px;">
                  <form action="/ezshm_crochem/users/<%= user.id %>/toggle-admin" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-action btn-toggle" title="تبديل الصلاحية">
                      <i class="fas fa-shield-alt"></i>
                      <%= user.is_admin ? 'إزالة المدير' : 'ترقية لمدير' %>
                    </button>
                  </form>
                  <form action="/ezshm_crochem/users/<%= user.id %>/delete" method="POST" style="display:inline;"
                    onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم؟');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-action btn-del">
                      <i class="fas fa-trash-alt"></i>
                      حذف
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>

</div>
</body>
</html>
