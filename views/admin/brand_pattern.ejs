<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>تحويل باترن بالبراند — Croshim Studio</title>
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.12.1/css/all.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700;800;900&family=Playfair+Display:ital,wght@1,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/pages/admin.css">
  <style>
    .bp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    @media(max-width:860px) { .bp-grid { grid-template-columns: 1fr; } }

    /* ── Upload card ── */
    .bp-card {
      background: #fff;
      border-radius: 20px;
      border: 1px solid rgba(196,99,122,.12);
      box-shadow: 0 4px 18px rgba(155,58,90,.07);
      overflow: hidden;
    }
    .bp-card-head {
      padding: .95rem 1.2rem;
      border-bottom: 1px solid rgba(155,58,90,.08);
      display: flex;
      align-items: center;
      gap: .6rem;
    }
    .bp-card-head h2 { font-weight: 900; font-size: .98rem; color: #6b1a30; margin: 0; }
    .bp-card-body { padding: 1.25rem; }

    /* Drop zone */
    .drop-zone {
      border: 2px dashed rgba(155,58,90,.3);
      border-radius: 16px;
      background: rgba(252,228,236,.22);
      padding: 2.4rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: .2s;
      position: relative;
    }
    .drop-zone:hover, .drop-zone.over {
      border-color: #9b3a5a;
      background: rgba(252,228,236,.45);
    }
    .drop-zone input[type="file"] {
      position: absolute; inset: 0;
      opacity: 0; cursor: pointer;
      width: 100%; height: 100%;
    }
    .drop-icon { font-size: 2.6rem; color: #e8a0b0; margin-bottom: .7rem; }
    .drop-label { font-weight: 800; color: #6b1a30; font-size: .95rem; margin-bottom: .3rem; }
    .drop-hint  { font-weight: 700; color: #9e677a; font-size: .8rem; }
    .drop-chosen {
      margin-top: .9rem;
      font-weight: 800;
      font-size: .85rem;
      color: #9b3a5a;
      display: none;
    }

    /* Rules list */
    .rules { margin-top: 1.1rem; display: flex; flex-direction: column; gap: .5rem; }
    .rule  { display: flex; align-items: flex-start; gap: .7rem; }
    .rule-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: linear-gradient(135deg, #9b3a5a, #e8a0b0);
      flex-shrink: 0; margin-top: 6px;
    }
    .rule-text { font-weight: 700; font-size: .84rem; color: #9e677a; line-height: 1.7; }
    .rule-text strong { color: #6b1a30; }

    /* Submit */
    .btn-brand {
      width: 100%;
      margin-top: 1.2rem;
      background: linear-gradient(135deg, #9b3a5a, #e8a0b0);
      color: #fff;
      border: 0;
      border-radius: 14px;
      padding: .92rem 1.5rem;
      font-weight: 900;
      font-size: .95rem;
      font-family: 'Cairo', sans-serif;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      box-shadow: 0 10px 28px rgba(155,58,90,.25);
      transition: .2s;
    }
    .btn-brand:hover  { filter: brightness(1.07); transform: translateY(-2px); }
    .btn-brand:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    /* ── Preview card ── */
    .preview-body {
      padding: 1.25rem;
      background: #f3e8ec;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    /* Mini A4 letterhead preview */
    .mini-a4 {
      width: 100%;
      max-width: 280px;
      aspect-ratio: 210 / 297;
      background: #fff;
      box-shadow: 0 8px 32px rgba(0,0,0,.18);
      border-radius: 12px;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
    }
    .ma-header {
      background: linear-gradient(135deg, #F9D4DC 0%, #F0A8B8 40%, #E07A94 100%);
      padding: 10px 14px 8px;
      flex-shrink: 0;
    }
    .ma-brand-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 6px;
    }
    .ma-brand-name {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 11px;
      color: #9B3A52;
      letter-spacing: 1px;
    }
    .ma-brand-tag {
      font-size: 4.5px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #C0516B;
    }
    .ma-title {
      text-align: center;
      font-size: 8px;
      color: #fff;
      font-weight: 700;
      padding: 3px 0;
    }
    .ma-dots {
      display: flex;
      gap: 3px;
      justify-content: center;
      padding: 4px;
      background: #fff;
    }
    .ma-dot {
      width: 4px; height: 4px; border-radius: 50%;
      background: #F4C2C2;
    }
    .ma-dot:nth-child(2) { background: #E8839A; }
    .ma-dot:nth-child(4) { background: #F9D4DC; }
    .ma-dot:nth-child(5) { background: #E8839A; }
    .ma-body {
      flex: 1;
      padding: 8px 10px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      overflow: hidden;
    }
    .ma-pill {
      background: linear-gradient(135deg, #F9D4DC, #F4C2C2);
      border-radius: 20px;
      height: 9px;
      width: 70%;
      align-self: flex-end;
    }
    .ma-code {
      background: #FDF5F7;
      border: 1px solid #EEC5CF;
      border-radius: 5px;
      height: 28px;
      width: 100%;
    }
    .ma-line {
      height: 3px;
      border-radius: 2px;
      background: #F4C2C2;
    }
    .ma-footer {
      background: linear-gradient(135deg, #F9D4DC, #F4C2C2);
      padding: 5px 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .ma-footer-brand {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 6px;
      color: #9B3A52;
    }
    .ma-footer-hearts { font-size: 5px; color: #E8839A; letter-spacing: 2px; }
    .ma-footer-num { font-size: 5px; color: #B8798A; }

    .preview-caption {
      font-weight: 700;
      font-size: .82rem;
      color: #9e677a;
      text-align: center;
      line-height: 1.9;
      max-width: 270px;
    }
    .preview-caption strong { color: #6b1a30; }
  </style>
</head>
<body>
<div class="admin-shell">

  <%- include('./_sidebar', { currentPage: 'brand-pattern' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-topbar-title">تحويل باترن بالبراند</h1>
      <span class="admin-topbar-user">
        <i class="fas fa-user-shield"></i>
        <%= adminUser.firstName %> <%= adminUser.lastName %>
      </span>
    </div>

    <div class="admin-content">

      <% if (successMessage) { %>
        <div class="admin-alert admin-alert-success"><i class="fas fa-check-circle"></i> <%= successMessage %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="admin-alert admin-alert-error"><i class="fas fa-exclamation-circle"></i> <%= errorMessage %></div>
      <% } %>

      <div class="bp-grid">

        <!-- Upload form -->
        <div class="bp-card">
          <div class="bp-card-head">
            <i class="fas fa-paint-brush" style="color:#9b3a5a;"></i>
            <h2>ارفع الباترن لتحويله</h2>
          </div>
          <div class="bp-card-body">
            <form action="/ezshm_crochem/brand-pattern" method="POST"
              enctype="multipart/form-data" onsubmit="handleSubmit(this)">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="drop-zone" id="dropZone">
                <input type="file" name="unify_pdf" accept="application/pdf,.pdf"
                  id="fileInput" required onchange="onFile(this)">
                <div class="drop-icon"><i class="fas fa-file-pdf"></i></div>
                <div class="drop-label">اسحب ملف PDF أو اضغط للاختيار</div>
                <div class="drop-hint">PDF فقط — حد أقصى 20 MB</div>
                <div class="drop-chosen" id="chosenName">
                  <i class="fas fa-check-circle" style="color:#9b3a5a;"></i>
                  <span id="chosenText"></span>
                </div>
              </div>

              <div class="rules">
                <div class="rule">
                  <div class="rule-dot"></div>
                  <div class="rule-text">كود الباترن (R1، R2، sc، inc…) <strong>لا يتغير أبداً</strong></div>
                </div>
                <div class="rule">
                  <div class="rule-dot"></div>
                  <div class="rule-text">يُضاف غلاف <strong>Croshim Studio</strong> بالألوان والخطوط الرسمية</div>
                </div>
                <div class="rule">
                  <div class="rule-dot"></div>
                  <div class="rule-text">العناوين والملاحظات تأخذ تنسيق البراند تلقائياً</div>
                </div>
                <div class="rule">
                  <div class="rule-dot"></div>
                  <div class="rule-text">تحميل مباشر — لا يُحفظ في قاعدة البيانات</div>
                </div>
              </div>

              <button type="submit" class="btn-brand" id="submitBtn">
                <i class="fas fa-magic"></i>
                تحويل بالبراند الآن
              </button>
            </form>

            <div style="margin-top:.9rem;text-align:center;">
              <div style="font-size:.78rem;font-weight:700;color:#9e677a;margin-bottom:.55rem;letter-spacing:.5px;">
                أو افتح القالب مباشرةً في Canva وعدّل يدوياً
              </div>
              <a href="https://canva.link/me98yofr5dq0rmt" target="_blank" rel="noopener"
                style="display:inline-flex;align-items:center;gap:.5rem;
                       background:#7d2ae8;color:#fff;border-radius:12px;
                       padding:.65rem 1.4rem;font-weight:800;font-size:.88rem;
                       font-family:'Cairo',sans-serif;text-decoration:none;
                       box-shadow:0 6px 20px rgba(125,42,232,.3);transition:.2s;"
                onmouseover="this.style.filter='brightness(1.1)'"
                onmouseout="this.style.filter='brightness(1)'">
                <i class="fas fa-external-link-alt"></i>
                فتح القالب في Canva
              </a>
            </div>
          </div>
        </div>

        <!-- Preview -->
        <div class="bp-card">
          <div class="bp-card-head">
            <i class="fas fa-eye" style="color:#9b3a5a;"></i>
            <h2>معاينة النتيجة</h2>
          </div>
          <div class="preview-body">
            <div class="mini-a4">
              <!-- Cover header -->
              <div class="ma-header">
                <div class="ma-brand-row">
                  <div>
                    <div class="ma-brand-name">croshim</div>
                    <div class="ma-brand-tag">crochet with heart</div>
                  </div>
                  <div style="font-size:14px;">🧶</div>
                </div>
                <div class="ma-title">اسم الباترن</div>
              </div>
              <!-- Dots -->
              <div class="ma-dots">
                <div class="ma-dot"></div><div class="ma-dot"></div>
                <div class="ma-dot"></div><div class="ma-dot"></div>
                <div class="ma-dot"></div><div class="ma-dot"></div>
              </div>
              <!-- Body simulation -->
              <div class="ma-body">
                <div class="ma-pill"></div>
                <div class="ma-code"></div>
                <div class="ma-pill" style="width:60%;margin-top:4px;"></div>
                <div class="ma-code" style="height:20px;"></div>
                <div class="ma-line" style="width:85%;margin-top:2px;"></div>
                <div class="ma-line" style="width:70%;"></div>
                <div class="ma-pill" style="width:65%;margin-top:4px;"></div>
                <div class="ma-code" style="height:36px;"></div>
              </div>
              <!-- Footer -->
              <div class="ma-footer">
                <div class="ma-footer-brand">croshim</div>
                <div class="ma-footer-hearts">🤍 🤍 🤍</div>
                <div class="ma-footer-num">١ / ١</div>
              </div>
            </div>

            <div class="preview-caption">
              كود الباترن يظهر <strong>حرفاً بحرف</strong> كما هو في ملفك الأصلي،
              بداخل بطاقات الكود الوردية مع غلاف <strong>Croshim Studio</strong> الكامل
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
const dz = document.getElementById('dropZone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('over'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('over');
  const f = e.dataTransfer.files[0];
  if (f) { document.getElementById('fileInput').files = e.dataTransfer.files; showName(f.name); }
});

function onFile(input) { if (input.files[0]) showName(input.files[0].name); }
function showName(n) {
  document.getElementById('chosenText').textContent = n;
  document.getElementById('chosenName').style.display = 'block';
}

function handleSubmit(form) {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحويل، قد يستغرق دقيقة…';
  setTimeout(() => {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-magic"></i> تحويل بالبراند الآن';
  }, 90000);
}
</script>
</body>
</html>
